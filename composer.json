{
    "name": "dalpras/form-zero",
    "description": "Yet another kind of forms: without the need of a view, low dependencies, rendering by decorators",
    "license": "proprietary",
    "type": "library",
    "require": {
        "php": ">=8.3",
        "dalpras/smart-template": "@dev",
        "laminas/laminas-validator": "^2.63",
        "laminas/laminas-filter": "^2.34",
        "laminas/laminas-i18n": "^2.30",
        "symfony/http-foundation": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3.6"
    },
    "autoload": {
        "psr-4": {
            "DalPraS\\FormZero\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DalPraS\\UnitTests\\": "tests/UnitTests/"
        }
    },
    "authors": [
        {
            "name": "Stefano Dal Prà"
        }
    ],
	"config": {
		"vendor-dir": "vendor",
		"allow-plugins": {
			"php-http/discovery": true
		}
	},
	"repositories": [
		{
			"type": "path",
			"url": "../smart-template",
			"options": {
				"symlink": true
			}
		}
	],    
	"minimum-stability" : "dev",
	"prefer-stable" : true
}
