{
    "name": "dalpras/form-zero",
    "description": "Yet another kind of forms: without the need of a view, low dependencies, rendering by decorators",
    "license": "proprietary",
    "type": "library",
    "require": {
        "php": ">=8.3",
        "dalpras/smart-template": "^4.0",
        "symfony/http-foundation": "^7.3",
        "symfony/mime": "^7.4",
        "symfony/validator": "^7.4",
        "symfony/psr-http-message-bridge": "^7.4",
        "symfony/translation": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3.6"
    },
    "autoload": {
        "psr-4": {
            "DalPraS\\FormZero\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DalPraS\\UnitTests\\": "tests/UnitTests/"
        }
    },
    "authors": [
        {
            "name": "Stefano Dal Prà"
        }
    ],
	"config": {
		"vendor-dir": "vendor",
		"allow-plugins": {
			"php-http/discovery": true
		}
	},
	"repositories": [
		{
			"type": "path",
			"url": "../smart-template",
			"options": {
				"symlink": true
			},
            "canonical": false
		}
	],    
	"minimum-stability" : "dev",
	"prefer-stable" : true
}
